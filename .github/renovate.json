{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":disableDependencyDashboard",
    ":separateMultipleMajorReleases",
    "helpers:pinGitHubActionDigests"
  ],

  "timezone": "Asia/Tokyo",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "assigneesFromCodeOwners": true,
  "vulnerabilityAlerts": { "enabled": true },
  "labels": ["CI/CD 🔁", "Deps 📦️"],

  "enabledManagers": ["github-actions", "custom.regex"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "2 weeks"
    },
    {
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "groupName": "GitHub Actions",
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "schedule": ["* * 1,15 * *"]
    },
    {
      "groupName": "Security",
      "matchPackageNames": ["zizmorcore/zizmor-action"],
      "schedule": ["* * 1,15 * *"],
      "addLabels": ["Security 🛡️"]
    },
    {
      "groupName": "chezmoi",
      "description": "Group chezmoi updates",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["home/\\.chezmoiversion$", "home/\\.chezmoiexternals/*\\.toml\\.tmpl$"],
      "addLabels": ["chezmoi 🏘️"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": ["Update Chezmoi version"],
      "managerFilePatterns": ["home/\\.chezmoiversion$"],
      "matchStrings": ["^(?<currentValue>.*)\\s$"],
      "depNameTemplate": "twpayne/chezmoi",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ]
}
