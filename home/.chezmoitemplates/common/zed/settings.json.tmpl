{{- /*
// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
*/ -}}
{
  "vim_mode": true,
  "restore_on_startup": "last_workspace",
  "auto_update": false,
  "telemetry": { "metrics": false, "diagnostics": false },
  {{/*
  // ===========================================================================
  // Appearance
  // ===========================================================================
  */ -}}
  "icon_theme": {{ .zed.theme.icon | quote }},
  "theme": {
    "light": {{ .zed.theme.light | quote }},
    "dark": {{ .zed.theme.dark | quote }},
    "mode": {{ .zed.theme.mode | quote }}
  },
  "bottom_dock_layout": "full",
  "relative_line_numbers": true,
  {{/* Font config */ -}}
  "buffer_font_family": {{ .font.family.combined | quote }},
  "buffer_font_size": {{ .font.size.medium }},
  "buffer_font_features": { "calt": true, "liga": true, "zero": true },
  "ui_font_family": {{ .font.family.combined | quote }},
  "ui_font_size": {{ .font.size.large }},
  {{/* Panel config */ -}}
  "project_panel": { "dock": "left" },
  "collaboration_panel": { "dock": "left" },
  "outline_panel": { "dock": "right" },
  "git_panel": {
    "button": true,
    "status_style": "icon"
  },
  {{/*
  // ===========================================================================
  // Navigation & Search
  // ===========================================================================
  */ -}}
  "file_finder": {
    "file_icons": true
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": false
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": true,
    "show_project_items": false,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
    "show_menus": true,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": true
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": false,
    "selected_symbol": false
  },
  "search": {"regex": true},
  "use_smartcase_search": true,
  {{/*
  // ===========================================================================
  // File Management
  // ===========================================================================
  */ -}}
  "autosave": "on_focus_change",
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/node_modules",
    "**/.venv",
    "**/venv",
    "**/__pycache__",
    "**/target",
    "**/.DS_Store",
    "**/.idea",
    "**/.vscode"
  ],
  "file_types": {
    "Dockerfile": ["Dockerfile.*"],
    "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
    "Git Config": [ "*.gitconfig", "**/{git,.git/modules,.git/modules/*}/config" ],
    "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
    "env": [".env", "**/.env*", "**/.envrc*"],
    "GitHub Actions": [ "**/.github/workflows/*.yaml", "**/.github/workflows/*.yml" ]
  },
  {{/*
  // ===========================================================================
  // Git
  // ===========================================================================
  */ -}}
  "git": {
    "inline_blame": { "enabled": false, "delay_ms": 500 }
  },
  {{/*
  // ===========================================================================
  // Terminal
  // ===========================================================================
  */ -}}
  "terminal": {
    "shell": { "program": {{ .shell | quote }} },
    "font_family": {{ .font.family.combined | quote }},
    "font_size": {{ .font.size.large }},
    "working_directory": "current_project_directory",
    "copy_on_select": false
  }
}
{{- /*
// -*-mode:jsonc-*- vim:ft=jsonc.gotexttmpl
*/ -}}
