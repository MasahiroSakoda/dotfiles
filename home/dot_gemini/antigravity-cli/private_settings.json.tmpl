{
  "allowNonWorkspaceAccess": true,
  "artifactReviewPolicy": "agent-decides",
  "colorScheme": "tokyo night",
  "editor": "auto",
  "enableTelemetry": false,
  "enableTerminalSandbox": false,
  "model": "Gemini 3.5 Flash (Medium)",
  "notifications": true,
  "permissions": {
    "allow": [
      "read_file(*)",
      "read_url(*)",
      "mcp(context7/*)",
      "mcp(grep_app/*)",
      "command(ls*)",
      "command(cat*)",
      "command(buf*)",
      "command(eza*)",
      "command(wc*)",
      "command(uniq)",
      "command(sort)",
      "command(grep*)",
      "command(rg*)",
      "command(find*)",
      "command(fd*)",
      "command(pwd)",
      "command(which*)",
      "command(make*)",
      "command(file*)",
      "command(type*)",
      "command(stat*)",
      "command(echo*)",
      "command(cut*)",
      "command(jq*)",
      "command(git (status|log|show|diff|add|blame)*)",
      "command(gh auth status)",
      "command(gh (status|search|branch))",
      "command(gh issue (list|view|status)*)",
      "command(gh pr (list|view|diff|status)*)",
      "command(pnpm run (build|dev|lint|test|e2e))",
      "command(bun run*)",
      "command(mise*)"
    ],
    "deny": [
      "command(su *)",
      "command(sudo *)",
      "command(rm -rf)",
      "command((wget|curl)*| (sh|bash|zsh|fish))",
      "command(npm|npx|yarn)",
      "command(pip|pip3|pipenv|poetry)",
      "write_file(~/.ssh)",
      "write_file(~/.gnupg)",
      "write_file(~/.aws)",
      "write_file(~/.gcp)",
      "read_file(.env*)",
      "read_file((cat|vim|nano|less|head|tail|base64|grep|sed|awk|sort|cut)\s+.*\.env\b(?!\.sample|\.example))",
      "write_file(.git/)"
    ],
    "ask": [
      "write_file(*)",
      "execute_url(*)",
      "command(chmod*)",
      "command(chown*)",
      "command(uname*)",
      "command(head*)",
      "command(tail*)",
      "command(more*)",
      "command(less*)",
      "command(sed*)",
      "command(awk*)",
      "command(xargs*)",
      "command(rm*)",
      "command(rmdir*)",
      "command(mv*)",
      "command(cp*)",
      "command(kill*)",
      "command(pkill*)",
      "command(killall*)",
      "command((wget|curl|aria2c|nc)*)",
      "command(git (commit|reset|rebase|pull|push)*)",
      "command(gh api * (PUT|POST|PATCH|DELETE))",
      "command(gh skill (search|preview|install|update|publish)*)",
      "command(pnpm (install|dlx)*)",
      "command(uv|uvx)"
    ]
  },
  "runningLightSpeed": "fast",
  "showFeedbackSurvey": false,
  "showTips": true,
  "statusLine": {
    "type": "command",
    "command": "bun run --silent -i ~/.gemini/antigravity-cli/scripts/statusline.ts",
    "enabled": true
  },
  "title": {
    "type": "command",
    "command": "bun run --silent -i ~/.gemini/antigravity-cli/scripts/title.ts",
    "enabled": true
  },
  "toolPermission": "request-review",
  "trustedWorkspaces": [
    {{ .chezmoi.workingTree | quote }},
    {{ joinPath .git.ghq_root .git.user | quote }}
  ],
  "verbosity": "low"
}
{{- /*
// -*-mode:jsonc-*- vim:ft=jsonc.gotexttmpl
*/ -}}
