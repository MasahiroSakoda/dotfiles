[install]
minimumReleaseAge = 604800      # 7 days in seconds
minimumReleaseAgeExcludes = ["@types/bun", "typescript"]

# whether to save the lockfile to disk
[install.lockfile]
save = true

[install.security]
scanner = "@socketsecurity/bun-security-scanner"

