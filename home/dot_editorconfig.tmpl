root = true

[*]
charset      = utf-8
end_of_line  = lf
indent_style = space
indent_size  = 2

insert_final_newline     = true
trim_trailing_whitespace = true

# Git
[{.gitconfig*,.git/config}]
indent_style = tab

# Markdown
[*.{md,mdx}]
indent_style = space
indent_size  = 2

# Shell Script
[*.{sh,zsh,fish,fish.symlink}]
indent_style = space
indent_size  = 2

# Makefile
[{Makefile}]
indent_style = tab
indent_size  = 4

# C/C++, Rust
[*.{c,cc,cpp,h,hpp,rs}]
indent_style = space
indent_size  = 4
tab_width    = 4

# Shader Languages
[*.{glsl,frag,vert,geom,comp,tese,tesc,metal}]
indent_style = space
indent_size  = 4
tab_width    = 4

# Go
[{*.{go},go.mod,go.sum,go.work}]
indent_style = tab
indent_size  = 4

# Java, Scala, Kotlin, Clojure
[*.{java,scala,kt,clj}]
indent_style = tab
indent_size  = 4

# JavaScript / Typescript
[*.{js,jsx,ts,tsx,cjs,cts,mjs,mts,vue,svelte,astro}]
indent_style = space
indent_size  = 2

# Lua
[*.{lua,lua.tmpl}]
max_line_length = 120

# Python
[*.{py,pyw}]
indent_style = space
indent_size  = 4
max_line_length = 120

# Ruby
[*.{rb,rbi,rbw,ru,gemspec,jbuilder,erb,slim,haml,Gemfile{,.lock},Rakefile,Guradfile,Brewfile,Caskfile,Masfile}]
max_line_length = 120

# TOML
[*.{toml}]
indent_style = space
indent_size  = 2

# JSON / YAML
[*.{json,jsonc,json5,y{a}ml}]
max_line_length = 120

# KDL
[*.{kdl,kdl.tmpl}]
indent_style = space
indent_size  = 4

# HTML & CSS
[*.{html,css,scss}]
indent_style    = tab
indent_size     = 2
max_line_length = 80

# TeX
[*.{tex,bib}]
indent_style = space
indent_size  = 2

# GraphQL
[*.{gql,graphql}]
indent_style    = tab
indent_size     = 2
max_line_length = 80

{{- /*
# -*-mode:editorconfig-*- vim:ft=editorconfig.gotexttmpl
*/ -}}
