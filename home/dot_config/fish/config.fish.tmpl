{{- /*
# -*-mode:fish-*- vim:ft=fish
*/ -}}

# Debugging
# set fish_trace 1

# Language/Locale Configuration
set -x LANG ja_JP.UTF-8
set -x LC_CTYPE ja_JP.UTF-8

# prevent layout collapsing in CLI tool
set -gx RUNEWIDTH_EASTASIAN 0

# Path Configuration
fish_add_path {{ .brew_prefix }}/bin
fish_add_path {{ .brew_prefix }}/sbin
fish_add_path $HOME/.local/bin

{{- if eq .chezmoi.arch "arm64" }}
set -gx ARCHFLAGS '-arch arm64'
{{- else if eq .chezmoi.arch "amd64" }}
set -gx ARCHFLAGS '-arch x86_64'
{{- end }}

# Editor
set -gx EDITOR nvim
set -gx VISUAL $EDITOR
set -gx NVIM_APPNAME nvim

# w3m
set -gx W3M_DIR "$XDG_CONFIG_HOME/w3m"

# Pager
set -gx PAGER "less"
# set -gx MANPAGER "sh -c 'col -bx | bat -l man -p --style=numbers'"
set -gx MANPAGER "nvim +Man!"
set -gx BAT_THEME "Monokai Extended Origin"
set -gx LESS "--ignore-case --RAW-CONTROL-CHARS --LONG-PROMPT -x-4 -z-4"
set -gx LESSCHARSET "utf-8"
set -gx LESS_TERMCAP_mb (printf "\e[01;31m")
set -gx LESS_TERMCAP_md (printf "\e[01;31m")
set -gx LESS_TERMCAP_me (printf "\e[0m")
set -gx LESS_TERMCAP_se (printf "\e[0m")
set -gx LESS_TERMCAP_so (printf "\e[01;42;30m")    # Search highlight
set -gx LESS_TERMCAP_ue (printf "\e[0m")
set -gx LESS_TERMCAP_us (printf "\e[01;32m")
set -gx LESSHISTFILE "$XDG_DATA_HOME/lesshst"

# Grep
set -x GREP_OPTIONS "--color=always"

# pinact
set -gx PINACT_MIN_AGE 7

# Fish Plugin
## Done notification
set -x __done_min_cmd_duration 60000  # default: 5000 ms

# Keybinds
bind ctrl-c cancel-commandline

# Fish abbreviations
abbr -a -- tl "tldr"
abbr -a -- cl "clear"
abbr -a -- x  "exit"

## File
abbr -a -- o    "open"
abbr -a -- oa   "open -a"
abbr -a -- mv   "mv -iv"
abbr -a -- cp   "cp -iv"
abbr -a -- cpr  "cp -R"
abbr -a -- rm   "rm -iv"
abbr -a -- rmf  "rm -if"
abbr -a -- rmrf "rm -rf"

## Directory
abbr -a -- cwd   "pwd | {{ .cmd.copy }}"
abbr -a -- mkdir "mkdir -pv"

### Moving directory: .*
abbr -a -- ..   "cd .."
abbr -a -- ...  "cd ../.."
abbr -a -- .... "cd ../../.."
abbr -a -- .2 "cd ../../"
abbr -a -- .3 "cd ../../../"
abbr -a -- .4 "cd ../../../../"
abbr -a -- .5 "cd ../../../../../"

## VCS
#
### Git: g*
abbr -a -- g   "git"
abbr -a -- gs  "git status"
abbr -a -- gl  "git log --all --graph"
abbr -a -- gmv "git mv --verbose"

abbr -a -- gd  "hunk diff"
abbr -a -- ga  "git add --verbose"
abbr -a -- grm "git rm"
abbr -a -- gsw "git switch"
abbr -a -- gco "git checkout"

abbr -a -- gf  "git fetch origin"
abbr -a -- gpl "git pull origin"
abbr -a -- gps "git push origin"

abbr -a -- grb  "git rebase"
abbr -a -- grba "git rebase --abort"
abbr -a -- grbc "git rebase --continue"
abbr -a -- grbi "git rebase --interactive"
abbr -a -- grbs "git rebase --skip"

abbr -a -- gt  "git tag | sort --version-sort --reverse"
abbr -a -- gta "git tag --annotate"
abbr -a -- gts "git tag --sign"

### Jujutsu (jj)

#### Core operations
abbr -a --           j   "jj status"
abbr -a --           jl  "jj log"
abbr -a --           jd  "jj desc"
abbr -a --set-cursor jD  "jj desc -m \"%\" "
abbr -a --           ja  "jj abandon"
abbr -a --           jn  "jj new"
abbr -a --set-cursor jN  "jj new -m \"%\""
abbr -a --           jrb "jj rebase"
abbr -a --           jc  "jj commit"
abbr -a --set-cursor jC  "jj commit -m \"%\""

#### Git related commands
abbr -a -- jcl "jj git clone"
abbr -a -- ji  "jj git init"
abbr -a -- jgf "jj git fetch"
abbr -a -- jgp "jj git push"

#### Editing changes
abbr -a -- je "jj edit"
abbr -a -- j- "jj edit @-"
abbr -a -- j+ "jj edit @+"
abbr -a -- js "jj split"

#### Operations
abbr -a -- jo  "jj op"
abbr -a -- jol "jj op log"
abbr -a -- ju  "jj undo"
abbr -a -- jjp "jj prev"
abbr -a -- jjn "jj next"

#### Conflict resolution
abbr -a -- jrsl "jj resolve"
abbr -a -- jrst "jj restore"

#### Bookmarks
abbr -a -- jb   "jj bookmark"
abbr -a -- jbc  "jj bookmark create"
abbr -a -- jbd  "jj bookmark delete"
abbr -a -- jbm  "jj bookmark move"
abbr -a -- jbs  "jj bookmark set"
abbr -a -- jbt  "jj bookmark track"

#### Workspaces
abbr -a -- jw   "jj workspace"
abbr -a -- jwl  "jj workspace list"
abbr -a -- jwr  "jj workspace root"
abbr -a -- jwa  "jj workspace add"
abbr -a -- jwf  "jj workspace forget"

### GitHub CLI: gh*
abbr -a -- ghd "gh dash"
abbr -a -- ghg "gh graph"
abbr -a -- ghn "gh notify"
abbr -a -- ghm "gh markdown-preview"
abbr -a -- ghp "gh poi"

#### Agent Skills via GitHub CLI
abbr -a -- ghs  "gh skill"
abbr -a -- ghss "gh skill search"
abbr -a -- ghsp "gh skill preview"
abbr -a -- ghsi "gh skill install"
abbr -a -- ghsu "gh skill update"

### mise
abbr -a -- m  "mise"
abbr -a -- mi "mise install"
abbr -a -- mu "mise upgrade"
abbr -a -- mr "mise run"
abbr -a -- mt "mise tasks"
abbr -a -- ms "__mise_registered_tools"
abbr -a -- ml "__mise_installed_tools"

## Docker: d*
abbr -a -- d docker
abbr -a -- dps "docker ps"
abbr -a -- dk  "docker kill"
abbr -a -- dp  "docker pull"
abbr -a -- dP  "docker push"
abbr -a -- dr  "docker run --rm"

### docker compose: dc*
abbr -a -- dc  "docker compose"
abbr -a -- dcb "docker compose build"
abbr -a -- dcu "docker compose up --build -d"
abbr -a -- dcd "docker compose down"
abbr -a -- dcl "docker compose logs"
abbr -a -- dcr "docker compose run --rm"
abbr -a -- dce "docker compose exec"
abbr -a -- dcs "docker compose stop"

### Node.js
abbr -a -- npm "pnpm"

#### pnpm: p*
abbr -a -- p  "pnpm"
abbr -a -- pi "pnpm install"
abbr -a -- pu "pnpm update"
abbr -a -- pa "pnpm add"
abbr -a -- pA "pnpm add -D"
abbr -a -- pr "pnpm rm"
abbr -a -- pR "pnpm rm -D"
abbr -a -- pb "pnpm build"
abbr -a -- pd "pnpm dev"
abbr -a -- po "pnpm outdated"
abbr -a -- pg "pnpm generate"
abbr -a -- pt "pnpm test"
abbr -a -- pe "pnpm e2e"
abbr -a -- pl "pnpm lint"
abbr -a -- px "pnpm dlx"
abbr -a -- pc "pnpm ci"
abbr -a -- pC "pnpm audit signatures"

#### aube: a*
abbr -a -- a  "aube"
abbr -a -- ai "aube install"
abbr -a -- au "aube update"
abbr -a -- aa "aube add"
abbr -a -- aA "aube add -D"
abbr -a -- ar "aube remove"
abbr -a -- aR "aube remove -D"
abbr -a -- ao "aube outdated"
abbr -a -- ab "aube build"
abbr -a -- ad "aube dev"
abbr -a -- at "aube test"
abbr -a -- ae "aube e2e"
abbr -a -- al "aube lint"
abbr -a -- ax "aube cowsay"
abbr -a -- ac "aube ci"
abbr -a -- aC "aube audit"

# Zellij: zl*
abbr -a -- zj  "zellij"
abbr -a -- zja "zellij attach --create"
abbr -a -- zjl "zellij --layout"
abbr -a -- zjp "zellij_picker"

# AI tools
abbr -a -- oc  "opencode"
abbr -a -- occ "opencode --continue"
abbr -a -- ocs "opencode --session"
abbr -a -- ocw "opencode web"

{{- /*
# @fish-lsp-disable 7001
*/ -}}
{{ if eq .chezmoi.os "darwin" }}
set -gx GITHUB_MCP_PAT        (security find-generic-password -s "MCP Server for GitHub" -w)
set -gx OPENAI_API_KEY        (security find-generic-password -s "OpenAI API Key" -w)
set -gx GOOGLE_API_KEY        (security find-generic-password -s "Google API Key" -w)
set -gx GEMINI_API_KEY        (security find-generic-password -s "Gemini API Key" -w)
set -gx AZURE_OPENAPI_API_KEY (security find-generic-password -s "Azure API Key" -w)
set -gx GROQ_API_KEY          (security find-generic-password -s "Groq API Key" -w)
set -gx DEEPL_API_KEY         (security find-generic-password -s "DeepL API Key" -w)
set -gx OPENCODE_API_KEY      (security find-generic-password -s "OpenCode Zen API Key" -w)
set -gx OPENROUTER_API_KEY    (security find-generic-password -s "OpenRouter API Key" -w)
set -gx OLLAMA_API_KEY        (security find-generic-password -s "Ollama Cloud API Key" -w)
set -gx CONTEXT7_API_KEY      (security find-generic-password -s "Context7 API Key" -w)
{{ else if eq .chezmoi.os "linux" }}
set -gx GITHUB_MCP_PAT        (secret-tool lookup username $USER key_name "MCP Server for GitHub")
set -gx OPENAI_API_KEY        (secret-tool lookup username $USER key_name "OpenAI API Key")
set -gx GOOGLE_API_KEY        (secret-tool lookup username $USER key_name "Google API Key")
set -gx GEMINI_API_KEY        (secret-tool lookup username $USER key_name "Gemini API Key")
set -gx AZURE_OPENAPI_API_KEY (secret-tool lookup username $USER key_name "Azure API Key")
set -gx GROQ_API_KEY          (secret-tool lookup username $USER key_name "Groq API Key")
set -gx DEEPL_API_KEY         (secret-tool lookup username $USER key_name "DeepL API Key")
set -gx OPENCODE_API_KEY      (secret-tool lookup username $USER key_name "OpenCode Zen API Key")
set -gx OPENROUTER_API_KEY    (secret-tool lookup username $USER key_name "OpenRouter API Key")
set -gx OLLAMA_API_KEY        (secret-tool lookup username $USER key_name "Ollama Cloud API Key")
set -gx CONTEXT7_API_KEY      (secret-tool lookup username $USER key_name "Context7 API Key")
{{ end }}
