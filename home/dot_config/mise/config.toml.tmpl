{{- /*
# -*-mode:toml-*- vim:ft=toml.gotexttmpl
*/ -}}
# -*-mode:toml-*- vim:ft=toml

[env]
# supports arbitrary env vars so mise can be used like direnv/dotenv
NODE_ENV = "development"

[settings]
verbose    = false # set to true to see full installation output, see `MISE_VERBOSE`
jobs       = 4     # number of plugins or runtimes to install in parallel. The default is `4`.
raw        = false # set to true to directly pipe plugins to stdin/stdout/stderr
yes        = false # set to true to automatically answer yes to all prompts
paranoid   = false # see https://mise.jdx.dev/paranoid.html
gpg_verify = true  # Use gpg to verify all tool signatures

# configure `mise install` to always keep the downloaded archive
always_keep_download = false        # deleted after install by default
always_keep_install  = false        # deleted on failure by default

install_before = "7d" # To limit supply chain risk

trusted_config_paths = [
  "~/Dev/repos/github.com/MasahiroSakoda",
]

experimental = true
lockfile     = true
pin          = true

env_file        = ".env" # load env vars from a dotenv file, see `MISE_ENV_FILE`
shorthands_file = "~/.config/mise/shorthand.toml"

disable_backends = ["asdf", "ubi", "vfox", "dotnet"] # backends to disable globally
disable_tools    = ["java"]                          # ignore specified tools in config files

[settings.npm]
# default_packages_file = "~/.config/mise/default-npm-packages"
package_manager = "pnpm"

[settings.python]
# default_packages_file = "~/.config/mise/default-python-packages"
uv_venv_auto = true

[settings.pipx]
uvx = true

[settings.ruby]
compile = false
# default_packages_file = "~/.config/mise/default-gems"

[tools]
# Backends
aqua = "latest"

# Completion
usage = "latest"

# Runtime & Languages
rust    = "1"
node    = "24"
pnpm    = "10"
deno    = "2"
bun     = "1"
go      = "1"
python  = ["3.14"]
ruby    = "3"

