toml-version = "v1.1.0"

[files]
include = ["**/*.toml"]
exclude = []

[format]

[lint]
[lint.rules]
dotted-keys-out-of-order = "warn"
key-empty                = "warn"
tables-out-of-order      = "warn"

[lsp]
code-action.enabled          = true
completion.enabled           = true
diagnostics.enabled          = true
document-link.enabled        = true
formatting.enabled           = true
goto-declaration.enabled     = true
goto-definition.enabled      = true
goto-type-definition.enabled = true
hover.enabled = true

[schema]
enabled = true
strict  = true

[schema.catalog]
paths = ["tombi://www.schemastore.org/api/json/catalog.json", "https://www.schemastore.org/api/json/catalog.json"]

[[schemas]]
root = "tool.taskipy"
path = "schemas/partial-taskipy.schema.json"
include = ["pyproject.toml"]

{{- /*
# -*-mode:toml-*- vim:ft=toml.gotexttmpl
*/ -}}
