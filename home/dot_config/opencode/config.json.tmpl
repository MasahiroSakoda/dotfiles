{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "snapshot": false,
  "model": {{ index .opencode.models.ultra 0 | quote }},
  "small_model": {{ index .opencode.models.elite 0 | quote }},
  {{/* Global plugins */ -}}
  "plugin": [
    // "superpowers@git+https://github.com/obra/superpowers.git",
    "@tarquinen/opencode-dcp@latest",
    "./plugins/damage-control.ts",
    "./plugins/notification.ts",
    "./plugins/limits.ts",
    "./plugins/rtk.ts"
  ],
  {{/* Global Instructions */ -}}
  "instructions": ["AGENTS.md", "CLAUDE.md"],
  {{/* Global Permissions */ -}}
  "permission": {
    "list": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "task": { "*": "allow" },
    "skill": { "*": "ask" },
    {{- $read := dict -}}
    {{- range .agents.permissions.read.allow -}}{{- $read = set $read . "allow" -}}{{- end }}
    {{- range .agents.permissions.read.ask -}}{{- $read = set $read . "ask" -}}{{- end }}
    {{- range .agents.permissions.read.deny -}}{{- $read = set $read . "deny" -}}{{- end }}
    {{- $edit := dict -}}
    {{- range .agents.permissions.write.allow -}}{{- $edit = set $edit . "allow" -}}{{- end }}
    {{- range .agents.permissions.write.ask -}}{{- $edit = set $edit . "ask" -}}{{- end }}
    {{- range .agents.permissions.write.deny -}}{{- $edit = set $edit . "deny" -}}{{- end }}
    {{- $bash := dict -}}
    {{- range .agents.permissions.bash.allow -}}{{- $bash = set $bash . "allow" -}}{{- end }}
    {{- range .agents.permissions.bash.ask -}}{{- $bash = set $bash . "ask" -}}{{- end }}
    {{- range .agents.permissions.bash.deny -}}{{- $bash = set $bash . "deny" -}}{{- end }}
    "read": {{ $read | toPrettyJson | indent 4 | trim }},
    "edit": {{ $edit | toPrettyJson | indent 4 | trim }},
    "bash": {{ $bash | toPrettyJson | indent 4 | trim }},
    "external_directory": {}
  },
  {{/* Compaction config */ -}}
  "compaction": { "auto": true, "prune": true },
  {{/* File Watcher Configurations */ -}}
  "watcher": {
    "ignore": [".git/**", ".jj/**", "**/*.log", "node_modules/**", "dist/**"]
  },
  {{/* Global AI Provider config */ -}}
  "enabled_providers": {{ .opencode.providers.enabled | toPrettyJson | indent 2 | trim }},
  "provider": {
    "opencode": {
      "name": {{ .ai.providers.opencode.name | quote }},
      "npm": {{ .ai.providers.opencode.npm | quote }},
      "options": {
        "baseURL": {{ .ai.providers.opencode.baseUrl | quote }},
        "apiKey": "{env:{{ substr 1 -1 .ai.providers.opencode.apiKey }}}"
      },
      {{- $whitelist := list -}}
      {{- range .ai.providers.opencode.models -}}{{ $whitelist = append $whitelist .id }}{{- end }}
      "whitelist": {{ $whitelist | toPrettyJson | indent 6 | trim }},
      {{- $models := dict }}
      {{- range .ai.providers.opencode.models }}{{- $models = set $models .id (dict "name" .name) -}}{{- end }}
      "models": {{ $models | toPrettyJson | indent 6 | trim }},
    },
    "openrouter": {
      "name": {{ .ai.providers.openrouter.name | quote }},
      "npm": {{ .ai.providers.openrouter.npm | quote }},
      "options": {
        "baseURL": {{ .ai.providers.openrouter.baseUrl | quote }},
        "apiKey": "{env:{{ substr 1 -1 .ai.providers.openrouter.apiKey }}}"
      },
      {{- $whitelist := list -}}
      {{- range .ai.providers.openrouter.models -}}{{ $whitelist = append $whitelist .id }}{{- end }}
      "whitelist": {{ $whitelist | toPrettyJson | indent 6 | trim }},
      {{- $models := dict }}
      {{- range .ai.providers.openrouter.models }}{{- $models = set $models .id (dict "name" .name) -}}{{- end }}
      "models": {{ $models | toPrettyJson | indent 6 | trim }},
    },
    "ollama-cloud": {
      "name": {{ .ai.providers.ollama.name | quote }},
      "npm": {{ .ai.providers.ollama.npm | quote }},
      "options": {
        "baseURL": {{ .ai.providers.ollama.baseUrl | quote }},
        "apiKey": "{env:{{ substr 1 -1 .ai.providers.ollama.apiKey }}}"
      },
      {{- $whitelist := list -}}
      {{- range .ai.providers.ollama.models -}}{{ $whitelist = append $whitelist .id }}{{- end }}
      "whitelist": {{ $whitelist | toPrettyJson | indent 6 | trim }},
      {{- $models := dict }}
      {{- range .ai.providers.ollama.models }}{{- $models = set $models .id (dict "name" .name) -}}{{- end }}
      "models": {{ $models | toPrettyJson | indent 6 | trim }},
    },
    "huggingface": {
      "name": {{ .ai.providers.huggingface.name | quote }},
      "npm": {{ .ai.providers.huggingface.npm | quote }},
      "options": {
        "baseURL": {{ .ai.providers.huggingface.baseUrl | quote }},
        "apiKey": "{env:{{ substr 1 -1 .ai.providers.huggingface.apiKey }}}"
      },
      {{- $whitelist := list -}}
      {{- range .ai.providers.huggingface.models -}}{{ $whitelist = append $whitelist .id }}{{- end }}
      "whitelist": {{ $whitelist | toPrettyJson | indent 6 | trim }},
      {{- $models := dict }}
      {{- range .ai.providers.huggingface.models }}{{- $models = set $models .id (dict "name" .name) -}}{{- end }}
      "models": {{ $models | toPrettyJson | indent 6 | trim }},
    },
  },
  {{/* Agent Configurations */ -}}
  "default_agent": "build",
  "agent": {
    {{/* Builtin Primary Agents */ -}}
    "plan": { "disable": false },
    "build": { "disable": false },
    {{/* Builtin Subagents */ -}}
    "general": { "disable": false },
    "explore": { "disable": false },
    "scout": { "disable": false },
    {{/* Custom Agents */ -}}
    "auditor": { "disable": false },
    "translator": { "disable": false },
    "triager": { "disable": false }
  },
  {{/* Formatter Configurations */ -}}
  "formatter": {
    "rumdl": { "command": [ "rumdl", "fmt", "--fix", "$FILE" ], "extensions": [ ".md", ".mdx" ] },
    "biome": { "command": [ "biome", "format", "$FILE" ], "extensions": [".js", "jsx", ".ts", ".tsx"] },
    "shfmt": { "command": ["shfmt", "$FILE"], "extensions": [".sh", ".bash", ".zsh"] },
    "ruff": { "command": [ "ruff", "format", "$FILE" ], "extensions": [".py", ".pyi"] },
    "stylua": { "command": [ "stylua", "$FILE" ], "extensions": [".lua"] },
    "yamlfmt": { "command": ["yamlfmt", "-formatter", "$FILE"], "extensions": [".yml", ".yaml"] },
    "rustfmt": { "command": ["rustfmt", "$FILE"], "extensions": [".rs"] },
    "gofmt": { "command": ["golangci-lint", "format", "$FILE"], "extensions": [".go"] }
  },
  {{/* Language Server Configurations */ -}}
  "lsp": {
    "rumdl": {
      "command": ["rumdl", "server"],
      "disabled": false,
      "extensions": [".md", ".markdown", ".mdx"]
    },
    "jsonls": {
      "command": ["vscode-json-languageserver", "--stdio"],
      "disabled": false,
      "extensions": [".json", ".jsonc"]
    },
    "yamlls": {
      "command": ["yaml-language-server", "--stdio"],
      "disabled": false,
      "extensions": [".yml", ".yaml"],
      "initialization": {
        "redhat": {"telemetry": { "enabled": true }},
        "yaml": {"schemas": { "https://www.schemastore.org/github-workflow.json": "/.github/workflows/*" }}
      }
    },
    "tombi": {
      "command": ["tombi", "lsp"],
      "disabled": false,
      "extensions": [".toml"]
    },
    "texlab": {
      "command": ["texlab"],
      "disabled": false,
      "extensions": [".tex", ".bib"]
    },
    "bashls": {
      "command": ["bash-language-server", "server"],
      "disabled": false,
      "extensions": [".sh", "bash"]
    },
    "fish-lsp": {
      "command": ["fish-lsp", "start"],
      "disabled": false,
      "extensions": [".fish"]
    },
    "clangd": {
      "command": ["clangd"],
      "disabled": false,
      "extensions": [".c", ".h", ".cpp", ".hpp", ".cc", ".hh", ".cxx", ".hxx", ".hcc"]
    },
    "rust_analyzer": {
      "command": ["rust_analyzer"],
      "disabled": false,
      "extensions": [".rs"]
    },
    "gopls": {
      "command": ["gopls", "serve"],
      "disabled": false,
      "extensions": [".go", ".mod", ".sum"]
    },
    "ty": {
      "command": ["ty", "server"],
      "disabled": false,
      "extensions": [".py"]
    },
    "biome": {
      "command": ["biome", "lsp-proxy"],
      "disabled": false,
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc", ".json5", ".html", ".css", ".vue", ".svelte", ".astro"]
    },
    "ts_ls": {
      "command": ["typescript-language-server", "--stdio"],
      "disabled": false,
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    },
    "denols": {
      "command": ["deno", "lsp"],
      "disabled": false,
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".vue", ".svelte", ".astro"]
    },
    "lua_ls": {
      "command": ["lua-language-server"],
      "disabled": false,
      "extensions": [".lua"]
    },
    "sqls": {
      "command": ["sqls"],
      "disabled": false,
      "extensions": [".sql"]
    },
    "dockerls": {
      "command": ["docker-langserver", "start", "--stdio"],
      "disabled": false,
      "extensions": ["Dockerfile", "Dockerfile.runtime"]
    },
    "terraform-ls": {
      "command": ["terraform-ls", "serve"],
      "disabled": false,
      "extensions": [".tf", ".hcl"]
    }
  },
  {{/* MCP Server Configurations */ -}}
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}" },
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "headers": {},
      "enabled": true
    }
  }
}
{{- /*
// -*-mode:json-*- vim:ft=json.gotexttmpl
*/ -}}
